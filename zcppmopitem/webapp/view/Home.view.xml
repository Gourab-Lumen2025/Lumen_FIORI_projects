<mvc:View
    controllerName="com.lumen.zcppmopitem.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:smartField="sap.ui.comp.smartfield"
    xmlns:table="sap.ui.table"
    height="100%">

    <f:DynamicPage headerExpanded="true">
        <!-- <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <svm:SmartVariantManagement id="svm" showExecuteOnSelection="true" />
                </f:heading>
                <f:expandedContent>
                    <Label text="Filter your data below" />
                </f:expandedContent>
                <f:snappedContent>
                    <Label text="Filters applied" />
                </f:snappedContent>
            </f:DynamicPageTitle>
        </f:title> -->

        <f:header>
            <f:DynamicPageHeader>
                <f:content>
                    <fb:FilterBar
                        id="filterbar"
                        persistencyKey="ZCPPMOPITEM_FILTERBAR"
                        useToolbar="false"
                        search=".onSearch"
                        filterChange=".onFilterChange"
                        afterVariantLoad=".onAfterVariantLoad">

                        <fb:filterGroupItems>
                            <fb:FilterGroupItem 
    name="BucketId" 
    label="Bucket ID" 
    groupName="Main"
    visibleInFilterBar="true">

    <fb:control>
        <smartField:SmartField
            value="{Bucket_ExternalId}"
            id="BucketIdInput"
            editable="true"/>
    </fb:control>

</fb:FilterGroupItem>

                            <fb:FilterGroupItem name="BucketInitiativeType" label="Initiative Type" groupName="Main" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="InitiativeTypeInput" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem name="BucketItemType" label="Item Type" groupName="Main" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="ItemTypeInput" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem name="InitiativeId" label="Initiative ID" groupName="Main" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="InitiativeIdInput" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem name="ItemId" label="Item ID" groupName="Main" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="ItemIdInput" />
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem name="ItemCompanyCode" label="Company Code" groupName="Main" visibleInFilterBar="true">
                                <fb:control>
                                    <Input id="CompanyCodeInput" />
                                </fb:control>
                            </fb:FilterGroupItem>
                        </fb:filterGroupItems>
                    </fb:FilterBar>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
        <ScrollContainer
		height="100%"
		width="100%"
		vertical="true"
		focusable="true">
            <table:TreeTable
                id="TreeTable"
                rows="{
                    path: 'tree>/',
                    parameters: { arrayNames:['children'] }
                }"
                visibleRowCount="auto"
                expandFirstLevel="true"
                selectionMode="None"
                columnHeaderHeight="40"
                enableColumnReordering="true"
                width="auto">

                <table:columns>
                    <table:Column width="auto" visible="false">
                        <Label text="Node" />
                        <table:template>
                            <Text text="{tree>NodeId}" visible="false" />
                        </table:template>
                    </table:Column>
                    <table:Column>
                        <Label text="Bucket ID" />
                        <table:template>
                            <Text text="{tree>Bucket_ExternalId}" width="auto" />
                        </table:template>
                    </table:Column>
                    <table:Column width="180px">
                        <Label text="Bucket Description" />
                        <table:template>
                            <Text text="{tree>Bucket_Desc}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="160px">
                        <Label text="Initiative ID" />
                        <table:template>
                            <Text text="{tree>Initiative_ExternalId}" />
                        </table:template>
                    </table:Column>
                     <table:Column width="180px">
                        <Label text="Initiative Description" />
                        <table:template>
                            <Text text="{tree>Initiative_Desc}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="160px">
                        <Label text="Item ID" />
                        <table:template>
                            <Text text="{tree>Item_ExternalId}" />
                        </table:template>
                    </table:Column>
                     <table:Column width="180px">
                        <Label text="Item Description" />
                        <table:template>
                            <Text text="{tree>Item_Desc}" />
                        </table:template>
                    </table:Column>
                    <table:Column width="160px">
                        <Label text="Actual Cost" />
                        <table:template>
                            <Text text="{tree>Bucket_ActualCost} {tree>Currency}" />
                        </table:template>
                    </table:Column>
                    
                    <!-- <table:Column width="180px">
                        <Label text="Variance %" />
                        <table:template>
                            <Text text="{tree>VariancePercent}" />
                        </table:template>
                    </table:Column> -->
                </table:columns>
            </table:TreeTable>
            </ScrollContainer>
        </f:content>
    </f:DynamicPage>
</mvc:View>